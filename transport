                pageLanguage: 'id', 
                includedLanguages: 'en,id,zh-CN,es,fr,de,ar,ru,ja,ko',
                autoDisplay: false
            }, 'google_translate_element');
        }

        function changeLanguage(langCode) {
            setTimeout(function() {
                var selectField = document.querySelector(".goog-te-combo");
                if (selectField) {
                    selectField.value = langCode;
                    selectField.dispatchEvent(new Event('change'));
                } else {
                    document.cookie = "googtrans=/id/" + langCode + "; path=/;";
                    document.cookie = "googtrans=/id/" + langCode + "; path=/; domain=" + window.location.hostname + ";";
                    window.location.reload();
                }
            }, 150);
        }
    </script>
    <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    <script>
        // Fungsi untuk scroll ke form dan otomatis memilih mobil
        function scrollToBook(vehicleValue) {
            // Scroll ke form
            document.getElementById('booking-form').scrollIntoView({ behavior: 'smooth' });
            
            // Set dropdown value
            setTimeout(() => {
                document.getElementById('t-vehicle').value = vehicleValue;
                // Highlight form sebentar untuk menarik perhatian
                const selectEl = document.getElementById('t-vehicle');
                selectEl.classList.add('ring-4', 'ring-green-400');
                setTimeout(() => selectEl.classList.remove('ring-4', 'ring-green-400'), 1500);
            }, 500);
        }

        // Fungsi kirim data form transport ke WhatsApp
        function submitTransportForm() {
            let name = document.getElementById("t-name").value;
            let wa = document.getElementById("t-wa").value;
            let vehicle = document.getElementById("t-vehicle").value;
            let pickup = document.getElementById("t-pickup").value;
            let dropoff = document.getElementById("t-dropoff").value;
            let date = document.getElementById("t-date").value;
            let time = document.getElementById("t-time").value;
            let pax = document.getElementById("t-pax").value;

            // Validasi sederhana
            if(!name || !vehicle || !pickup || !dropoff || !date) {
                alert("Mohon lengkapi sekurang-kurangnya: Nama, Kendaraan, Lokasi Jemput/Tujuan, dan Tanggal.");
                return;
            }

            // Pesan diformat rapi
            let text = `Halo *Rinjani Eagle Transport*, saya ingin memesan layanan Transportasi Privat:%0A%0A` +
                       `👤 *Nama:* ${name}%0A` +
                       `📱 *No. WhatsApp:* ${wa}%0A` +
                       `🚙 *Armada:* ${vehicle}%0A` +
                       `📍 *Lokasi Jemput:* ${pickup}%0A` +
                       `🏁 *Tujuan Antar:* ${dropoff}%0A` +
                       `📅 *Tanggal:* ${date}%0A` +
                       `⏰ *Jam Jemput:* ${time}%0A` +
                       `👥 *Jumlah Penumpang & Barang:* ${pax}%0A%0A` +
                       `Mohon konfirmasi harga total dan ketersediaan armadanya. Terima kasih.`;

            // Buka link WhatsApp (Gunakan nomor WA yang sama dengan main form)
            window.open(`https://wa.me/6285731826312?text=${text}`, '_blank');
        }

        // Animasi Scroll
        const observer = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if(entry.isIntersecting){
                    entry.target.classList.add('show');
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.fade-up').forEach(el => {
            observer.observe(el);
        });
    </script>
</body>
</html>
